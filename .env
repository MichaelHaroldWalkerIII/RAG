# ================================================================
# Enhanced RAG System - API Keys Configuration
# ================================================================
# IMPORTANT: This file contains secrets - never commit to git!
# Add this file to your .gitignore immediately after creating it
# ================================================================

# ================================================================
# PRIMARY API KEYS (Recommended for best results)
# ================================================================

# NewsAPI - Breaking news from 70,000+ sources worldwide
# Free tier: 1,000 requests/month | Paid: $449/month for unlimited
# Get your key at: https://newsapi.org/register
# Required for: Latest news, current events, breaking stories
NEWS_API_KEY=60476a30cdcd474893ccf62693f57f69

# GitHub Personal Access Token - Access to repositories and documentation
# Free for public repos | Required for private repos
# Get your token at: https://github.com/settings/tokens
# Permissions needed: public_repo (or repo for private access)
# Required for: Code examples, documentation, README files, technical guides
GITHUB_TOKEN=ghp_your_github_token_here

# ================================================================
# ENHANCED SEARCH APIs (Optional but powerful)
# ================================================================

# Serper API - Google Search alternative with clean API
# Free tier: 2,500 searches/month | Paid: $50/month for 100k searches
# Get your key at: https://serper.dev/
# Required for: High-quality Google search results, current web content
SERPER_API_KEY=your_serper_key_here

# Bing Search API - Microsoft's search engine API
# Free tier: 1,000 queries/month | Paid: $4/1k queries
# Get your key at: https://portal.azure.com/ (Cognitive Services)
# Required for: Web search, current content, news articles
BING_SEARCH_KEY=your_bing_key_here

# ================================================================
# AI/LLM APIs (For enhanced response generation)
# ================================================================

# OpenAI API - GPT models for high-quality text generation
# Paid service: ~$0.002 per 1k tokens for GPT-3.5-turbo
# Get your key at: https://platform.openai.com/api-keys
# Required for: Better answer generation, summarization, analysis
OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic Claude API - Alternative to OpenAI
# Paid service with free trial credits
# Get your key at: https://console.anthropic.com/
# Required for: High-quality reasoning, analysis, code generation
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Cohere API - Another AI alternative with good free tier
# Free tier: 100 API calls/month | Paid: $1 per 1k generations
# Get your key at: https://dashboard.cohere.ai/
# Required for: Text generation, embeddings, classification
COHERE_API_KEY=your_cohere_key_here

# ================================================================
# SPECIALIZED APIS (For domain-specific searches)
# ================================================================

# Alpha Vantage - Financial and economic data
# Free tier: 5 API requests per minute, 500 per day
# Get your key at: https://www.alphavantage.co/support/#api-key
# Required for: Stock data, financial news, economic indicators
ALPHA_VANTAGE_KEY=your_alphavantage_key_here

# NASA API - Space and science data
# Free with registration
# Get your key at: https://api.nasa.gov/
# Required for: Space news, scientific data, astronomy content
NASA_API_KEY=your_nasa_key_here

# Weather API - Current weather and forecasts
# Free tier: 1,000 calls/day | Paid: $40/month for 100k calls
# Get your key at: https://openweathermap.org/api
# Required for: Weather data, climate information
WEATHER_API_KEY=your_weather_key_here

# ================================================================
# SOCIAL MEDIA & DISCUSSION APIS (Optional)
# ================================================================

# Reddit API - Access to Reddit discussions and content
# Free with registration
# Get your credentials at: https://www.reddit.com/prefs/apps
# Required for: Current discussions, community insights, opinions
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=YourAppName/1.0

# Twitter/X API - Access to tweets and trends (if available)
# Paid service since 2023
# Get your key at: https://developer.twitter.com/
# Required for: Real-time discussions, trending topics, public sentiment
TWITTER_API_KEY=your_twitter_key_here
TWITTER_API_SECRET=your_twitter_secret_here

# ================================================================
# DATABASE & STORAGE CONFIGURATION
# ================================================================

# Database URL for storing cached content and embeddings
# SQLite (default): sqlite:///rag_cache.db
# PostgreSQL: postgresql://user:password@localhost/rag_db
# MySQL: mysql://user:password@localhost/rag_db
DATABASE_URL=sqlite:///rag_cache.db

# Redis URL for caching (optional but recommended for production)
# Local: redis://localhost:6379
# Remote: redis://user:password@host:port/db
REDIS_URL=redis://localhost:6379

# ================================================================
# RAG SYSTEM CONFIGURATION
# ================================================================

# Text chunking settings
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200

# Search and retrieval settings
RAG_MAX_SOURCES=15
RAG_MAX_CHUNKS_PER_SOURCE=3
RAG_SIMILARITY_THRESHOLD=0.7

# Source authority and filtering
RAG_AUTHORITY_THRESHOLD=0.6
RAG_MAX_AGE_DAYS=30

# Rate limiting (requests per minute)
RAG_RATE_LIMIT_NEWS=10
RAG_RATE_LIMIT_GITHUB=30
RAG_RATE_LIMIT_SEARCH=5

# Model settings
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_LLM_MODEL=gpt-3.5-turbo
RAG_MAX_TOKENS=1000
RAG_TEMPERATURE=0.7

# ================================================================
# DEVELOPMENT & DEBUGGING
# ================================================================

# Debug mode (set to 'true' for verbose logging)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable specific debug features
DEBUG_SEARCH=false
DEBUG_EMBEDDINGS=false
DEBUG_LLM=false

# ================================================================
# PRODUCTION SETTINGS
# ================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Security settings
SECRET_KEY=your_secret_key_for_sessions_here
ALLOWED_HOSTS=localhost,127.0.0.1

# Performance settings
MAX_WORKERS=4
TIMEOUT_SECONDS=30
CACHE_TTL_SECONDS=3600

# ================================================================
# QUICK START GUIDE
# ================================================================
# 1. Get NewsAPI key (2 minutes): https://newsapi.org/register
# 2. Get GitHub token (2 minutes): https://github.com/settings/tokens
# 3. Replace 'your_key_here' with your actual keys above
# 4. Save this file as '.env' in your project root
# 5. Make sure '.env' is in your .gitignore file
# 6. Run your Enhanced RAG system!
#
# Priority order for getting keys:
# 1. NEWS_API_KEY (essential for current content)
# 2. GITHUB_TOKEN (essential for technical content)
# 3. OPENAI_API_KEY (better responses but costs money)
# 4. SERPER_API_KEY (better search results)
# 5. Others as needed for specific domains
# ================================================================